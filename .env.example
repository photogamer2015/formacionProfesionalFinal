# Copia este archivo como ".env" en la raíz del proyecto y rellena los
# valores. El archivo .env real está ignorado por Git (ver .gitignore),
# así que NUNCA termina en el repositorio.

# ─── Seguridad ──────────────────────────────────────────────────────
# En producción genera una clave aleatoria:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-de-50-caracteres
DEBUG=True

# ─── Base de datos ──────────────────────────────────────────────────
# Si DEJAS VACÍO DB_NAME, Django usa SQLite (db.sqlite3 en la raíz).
# Esto es lo recomendado para empezar / desarrollo local.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ─── MercyBot / OpenAI ──────────────────────────────────────────────
# Clave de la API de OpenAI para el asistente MercyBot.
# Consíguela en https://platform.openai.com/api-keys
# Si la dejas vacía, MercyBot funciona en modo básico (sin IA).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Correo para códigos de acceso ─────────────────────────────────
# Para Gmail usa una "contraseña de aplicación", no la contraseña normal.
# Ejemplo:
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=formacionprofesional.edu.ec@gmail.com
#   EMAIL_HOST_PASSWORD=tu-clave-de-aplicacion
#   EMAIL_USE_TLS=True
#   DEFAULT_FROM_EMAIL=formacionprofesional.edu.ec@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=formacionprofesional.edu.ec@gmail.com
EMAIL_HOST_PASSWORD=tu-clave-de-aplicacion
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=formacionprofesional.edu.ec@gmail.com
